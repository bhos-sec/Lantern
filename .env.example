# ── Server ────────────────────────────────────────────────────────────────────

# Port the Express + Socket.IO server listens on.
# Default: 3000
PORT=3000

# Set to "production" to serve the Vite dist/ build instead of running Vite middleware.
# Default: development
NODE_ENV=development

# ── Rate Limiting ─────────────────────────────────────────────────────────────

# Maximum chat messages (room + DM combined) per socket within MSG_RATE_WINDOW_MS.
# Default: 10
# MSG_RATE_MAX=10

# Rolling window duration in milliseconds for the message rate limit.
# Default: 5000
# MSG_RATE_WINDOW_MS=5000

# Hard cap on chat message length in characters.
# Default: 500
# MAX_MSG_LENGTH=500

# Minimum milliseconds a socket must wait between consecutive join-room attempts.
# Default: 3000
# JOIN_COOLDOWN_MS=3000

# ── Optional AI Features ──────────────────────────────────────────────────────

# Google Gemini API key (reserved for future AI features — not required to run).
# GEMINI_API_KEY=
